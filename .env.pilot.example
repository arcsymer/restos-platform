# ============================================================================
# RestOS PILOT configuration — copy to `.env`, fill in, and NEVER commit `.env`.
#
# PILOT SOFTWARE. Synthetic data by default. This is NOT a certified production
# or point-of-sale system: no real payments, no fiscal receipts (KSeF), no
# compliance guarantees. See PILOT_BOUNDARIES.md.
#
# `scripts/pilot.ps1 check-env` (or `pilot.sh check-env`) fails fast if any
# REQUIRED value below is missing or still a "change-me" placeholder.
# ============================================================================

# --- Postgres (backs restos-core) -------------------------------------------
POSTGRES_USER=restos
POSTGRES_PASSWORD=change-me-strong-password      # REQUIRED: a real, strong password
POSTGRES_DB=restos

# --- restos-portal auth secrets ---------------------------------------------
JWT_ACCESS_SECRET=change-me-to-a-long-random-string        # REQUIRED
JWT_REFRESH_SECRET=change-me-to-a-different-long-random    # REQUIRED

# --- Grafana admin (dashboards at :3001) ------------------------------------
GF_ADMIN_PASSWORD=change-me

# --- Venue seed (real-data readiness) ---------------------------------------
# Point at your venue's JSON to load a real menu + tables + identity without
# code changes (see restos-core/venue.example.json). Leave BLANK to run on the
# synthetic demo venue.
RESTOS_VENUE_SEED=

# --- Admin API key (pilot/sandbox auth for admin/data endpoints) ------------
# Guards the menu-import + GDPR-delete endpoints with an X-Admin-Key header.
# This is pilot-grade shared-secret auth, NOT a production identity system.
RESTOS_ADMIN_KEY=change-me
