{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "RestOS — Live Stack Overview",
  "uid": "restos-overview",
  "tags": ["restos"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scrape targets up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [ { "refId": "A", "expr": "count(up == 1)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "restos-core uptime",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "process_uptime_seconds{job=\"restos-core\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "restos-core — HTTP request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"restos-core\"}[1m]))", "legendFormat": "{{uri}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "restos-core — JVM heap used",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum(jvm_memory_used_bytes{job=\"restos-core\", area=\"heap\"})", "legendFormat": "heap used", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Metrics via OTel Collector hop (re-export :8889)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"otel-collector-export\"}[1m]))", "legendFormat": "{{uri}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 99,
      "type": "text",
      "title": "",
      "transparent": true,
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 16 },
      "options": { "mode": "markdown", "content": "RestOS observability &nbsp;·&nbsp; built by **@arcsymer**" }
    }
  ]
}
