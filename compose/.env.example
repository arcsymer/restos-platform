# Copy to `.env` (gitignored) to override the safe local defaults baked into
# docker-compose.full.yml. Every value here is a LOCAL DEV default — not a secret.
POSTGRES_USER=restos
POSTGRES_PASSWORD=restos
POSTGRES_DB=restos

# restos-portal JWT signing (any non-empty strings work locally)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Grafana admin password (anonymous viewer access is on regardless)
GF_ADMIN_PASSWORD=admin
